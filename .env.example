# =============================================================================
# Mana-Mingle (we-connect) – Environment variables
# =============================================================================
# Copy this file to .env and fill in real values. Never commit .env to git.
# All secrets (ADMIN_KEY, TURN_*, etc.) must stay in .env only.
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Security (required for admin panel in production) ---
# Strong random string; e.g. run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=Lokesh@0802

# --- CORS (production) ---
# Comma-separated allowed origins for API and Socket.IO (no spaces)
# Example: https://yoursite.com,https://www.yoursite.com
FRONTEND_ORIGIN=http://localhost:5173

# --- WebRTC TURN (optional) ---
# Only needed if users are behind strict NAT/firewall. Leave empty to use STUN only.
# TURN_USERNAME=
# TURN_PASSWORD=

# --- Optional: custom .env path ---
# DOTENV_CONFIG_PATH=/absolute/path/to/.env
