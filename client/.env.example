# =============================================================================
# Mana-Mingle client – optional environment variables (Vite)
# =============================================================================
# Copy to .env.local for local overrides. Do NOT put secrets here:
# Vite embeds VITE_* variables in the build; they are visible to users.
# =============================================================================

# Optional: Socket server URL when API is on a different origin (e.g. production)
# Leave empty to use current origin. Example: https://api.yoursite.com
# VITE_SOCKET_URL=
